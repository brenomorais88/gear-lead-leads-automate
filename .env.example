# Copie para .env na raiz do projeto (ou exporte no shell).
# O app carrega .env automaticamente; variáveis já no ambiente do processo têm prioridade.
# Não commite tokens reais.

# --- Infra do container/app
# Porta publicada no host (Docker mapeia HOST:3000 — o app escuta na 3000 dentro do container).
APP_PORT=3000
SQLITE_PATH=/app/data/lead-engine.db

# --- Webhook estável (opcional): perfil Docker "tunnel-stable" (Cloudflare Named Tunnel).
# Painel: Zero Trust → Networks → Tunnels → criar túnel → Public Hostname → serviço http://app:PORT (mesma rede do compose).
# CLOUDFLARE_TUNNEL_TOKEN=

# --- Deploy sem build no servidor (docker-compose.deploy.yml + imagem da esteira GHCR)
# DEPLOY_IMAGE=ghcr.io/brenomorais88/gear-lead-leads-automate:integracao_whats

# --- HTTPS (Caddy): subdomínio com DNS A → IP do servidor; compose com --profile https (ver README_DEPLOY.md)
# PUBLIC_HOST=webhook.brenomorais.com.br

# --- Infra / segredos (sempre lidos do ambiente; não vão para o banco)
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Opcional: worker / fila (permanecem só no ambiente)
# WHATSAPP_WORKER_POLL_SECONDS=30
# WHATSAPP_PROCESSING_STALE_SECONDS=600
# WHATSAPP_QUOTA_DEFER_MINUTES=15

# --- Operacional (usados só para criar a 1ª linha em whatsapp_settings se o banco estiver vazio).
# Depois disso a fonte da verdade é o banco; edite em http://localhost:3000/whatsapp/config (ou GET/PUT /whatsapp/settings).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_TEMPLATE_NAME=gear_lead_intro_v1
WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=pt_BR
WHATSAPP_DAILY_SEND_LIMIT=100
WHATSAPP_SEND_DELAY_MIN_MINUTES=5
WHATSAPP_SEND_DELAY_MAX_MINUTES=30
